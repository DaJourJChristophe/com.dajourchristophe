{
  "name": "com.dajour",
  "version": "1.1.0",
  "description": "",
  "main": "build/service/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "gulp --gulpfile ./gulpfile.js build",
    "build:dev": "gulp --gulpfile ./gulpfile.js dev",
    "build:prod": "gulp --gulpfile ./gulpfile.js prod",
    "build:server": "gulp --gulpfile ./gulpfile.js service:dev",
    "build:service": "gulp --gulpfile ./gulpfile.js service:dev",
    "ci": "npm run build:dev && npm run test:unit && npm run uat",
    "watch": "gulp --gulpfile ./gulpfile.js watch",
    "dev:container": "node scripts/dev-container.cjs",
    "start": "node build/service/index.js",
    "serve": "npm run build:dev && npm run start",
    "test": "npm run test:unit",
    "test:unit": "npm run build:dev && node --test test/unit/*.test.js",
    "uat": "npm run build:dev && gulp --gulpfile ./gulpfile.js uat",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "gulp": "^5.0.1",
    "gulp-clean-css": "^4.3.0",
    "gulp-rename": "^2.1.0",
    "gulp-uglify": "^3.0.2",
    "pug": "^3.0.4",
    "sass": "^1.99.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@sentry/node": "^10.48.0",
    "express": "^5.2.1"
  }
}
